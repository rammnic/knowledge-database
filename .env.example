# Database (PostgreSQL)
DATABASE_URL="postgresql://knowledge:your-secure-password@localhost:5432/knowledge"
DB_PASSWORD="your-secure-password"

# Security
SECRET_TOKEN="your-admin-secret-token-change-in-production"

# Client-side security (for dev - expose to frontend)
NEXT_PUBLIC_SECRET_TOKEN="your-admin-secret-token"

# AI (OpenRouter) - используется для оптимизации и embeddings
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENROUTER_MODEL="google/gemini-2.0-flash-001"

# App URL (required for server-side API calls)
NEXT_PUBLIC_URL="http://localhost:3000"

# Optional: NextAuth secret (if using NextAuth)
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"
